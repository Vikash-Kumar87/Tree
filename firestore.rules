rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── measurements collection ───────────────────────────────
    match /measurements/{docId} {

      // Only the owner can read their own measurement
      allow get: if request.auth != null
                 && (resource == null || resource.data.userId == request.auth.uid);

      // Only the owner can list their measurements
      // (resource is null in list queries; filter is enforced client-side via where clause)
      allow list: if request.auth != null;

      // Authenticated users can create their own records
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      // Owner can update / delete
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

  }
}
