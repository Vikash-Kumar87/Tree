# ─── Environment variables (NEVER commit) ──────────────────────────────────
.env
*.env
.env.local
.env.production

# ─── Firebase credentials ───────────────────────────────────────────────────
*-adminsdk*.json
firebase-adminsdk.json

# ─── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ─── Node / Frontend ────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.env

