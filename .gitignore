!backend/weights/yolov8_tree.pt

# ─── Training Runs ──────────────────────────────────────────────────────────
runs/
outputs/
wandb/

# ─── IDE ────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp

# ─── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Docker ─────────────────────────────────────────────────────────────────
ssl/

# ─── Logs ───────────────────────────────────────────────────────────────────
*.log
logs/
